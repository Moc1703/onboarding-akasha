# ── Google Sheet Integration (optional) ──
# If set, intern data will be fetched from this Google Sheet.
# If not set, hardcoded data in src/data/interns.ts is used as fallback.
#
# How to get the URL:
# 1. Open your Google Sheet
# 2. File → Share → Publish to web
# 3. Select "Entire document" → "Comma-separated values (.csv)"
# 4. Click Publish
# 5. Copy the published URL and paste below
#
# Required sheet columns:
#   id, name, department, startDate, accessExpires, accessKey
#
# Department names can be short (e.g. "PA") or full (e.g. "PA Department")
# quizUrl and sopFile are auto-assigned based on department (see src/data/department-config.ts)
# accessExpires can be a simple date like "6 April 2026" or full ISO format

GOOGLE_SHEET_CSV_URL=

# ── 1Password Credentials (required) ──
# Shared 1Password account credentials served to interns after access key verification.
# These are NEVER stored in source code — only in Vercel environment variables.

ONBOARD_1P_ACCOUNT=
ONBOARD_1P_PASSWORD=
ONBOARD_1P_SECRET_KEY=
