# ── Google Sheet Integration (optional) ──
# If set, intern data will be fetched from this Google Sheet.
# If not set, hardcoded data in src/data/interns.ts is used as fallback.
#
# How to get the URL:
# 1. Open your Google Sheet
# 2. File → Share → Publish to web
# 3. Select "Entire document" → "Comma-separated values (.csv)"
# 4. Click Publish
# 5. Copy the published URL and paste below
#
# Required sheet columns:
#   id, name, department, startDate, accessExpires, accessKey
#
# Department names can be short (e.g. "PA") or full (e.g. "PA Department")
# quizUrl and sopFile are auto-assigned based on department (see src/data/department-config.ts)
# accessExpires can be a simple date like "6 April 2026" or full ISO format

GOOGLE_SHEET_CSV_URL=

# ── 1Password Credentials (required) ──
# Shared 1Password account credentials served to interns after access key verification.
# These are NEVER stored in source code — only in Vercel environment variables.

ONBOARD_1P_ACCOUNT=
ONBOARD_1P_PASSWORD=
ONBOARD_1P_SECRET_KEY=

# ── Login IP Logging (optional) ──
# Google Apps Script Web App URL for logging intern login attempts (IP, user agent, status).
# If not set, logs are only written to console (visible in Vercel Function Logs).
#
# How to set up:
# 1. Open your Google Sheet → Extensions → Apps Script
# 2. Paste the doPost function from the README
# 3. Deploy → New deployment → Web app → "Anyone" access
# 4. Copy the deployment URL and paste below

LOGIN_LOG_WEBHOOK_URL=

# ── Admin Dashboard (optional) ──
# Secret key to access the admin dashboard at /admin.
# Set this to any strong string and share only with admins.

ADMIN_SECRET=

# ── Login Log CSV (optional) ──
# Published CSV URL for the "Login Logs" tab in Google Sheets.
# Required for viewing login history in the admin dashboard.
#
# How to get the URL:
# 1. Google Sheet → File → Share → Publish to web
# 2. Select tab "Login Logs" → format "CSV"
# 3. Copy the URL and paste below

LOGIN_LOG_CSV_URL=
